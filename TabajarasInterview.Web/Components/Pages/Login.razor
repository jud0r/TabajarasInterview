@page "/login"
@inject IAuthApiService AuthApi
@inject AuthService AuthService
@inject NavigationManager Navigation

<AuthorizeView>
    <NotAuthorized Context="notAuthorized">
        <PageTitle>Sign in</PageTitle>

        <MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="mt-16">
            <MudPaper Class="pa-8" Elevation="4">
                <MudText Typo="Typo.h5" GutterBottom="true">Sign in</MudText>

                <EditForm Model="_model" OnValidSubmit="HandleLoginAsync">
                    <DataAnnotationsValidator />

                    <MudTextField @bind-Value="_model.Email"
                                  For="@(() => _model.Email)"
                                  Label="Email"
                                  InputType="InputType.Email"
                                  Variant="Variant.Outlined"
                                  Class="mb-4" />

                    <MudTextField @bind-Value="_model.Password"
                                  For="@(() => _model.Password)"
                                  Label="Password"
                                  InputType="InputType.Password"
                                  Variant="Variant.Outlined"
                                  Class="mb-4" />

                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
                    }

                    <MudButton ButtonType="ButtonType.Submit"
                               Color="Color.Primary"
                               Variant="Variant.Filled"
                               FullWidth="true"
                               Disabled="_busy">
                        @(_busy ? "Signing in..." : "Sign in")
                    </MudButton>
                </EditForm>
            </MudPaper>
        </MudContainer>
    </NotAuthorized>
</AuthorizeView>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationState { get; set; }

    private readonly LoginRequest _model = new();
    private string? _error;
    private bool _busy;

    [Parameter]
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // Authenticated users should never see the login form; redirect them once
        // from a lifecycle method instead of during rendering.
        if (AuthenticationState is null)
            return;

        var state = await AuthenticationState;
        if (state.User.Identity?.IsAuthenticated == true)
        {
            var destination = string.IsNullOrWhiteSpace(ReturnUrl) ? "/" : ReturnUrl;
            Navigation.NavigateTo(destination, replace: true);
        }
    }

    private async Task HandleLoginAsync()
    {
        _busy = true;
        _error = null;

        var result = await AuthApi.LoginAsync(_model);
        if (result is { Success: true, Data: not null })
        {
            await AuthService.LoginAsync(result.Data);

            var destination = string.IsNullOrWhiteSpace(ReturnUrl) ? "/" : ReturnUrl;
            Navigation.NavigateTo(destination);
            return;
        }

        _error = result.ErrorMessage ?? "Invalid email or password.";
        _busy = false;
    }
}
