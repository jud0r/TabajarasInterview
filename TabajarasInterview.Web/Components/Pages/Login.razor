@page "/login"
@layout HomeLayout
@inject IAuthApiService AuthApi
@inject AuthService AuthService
@inject NavigationManager Navigation

<AuthorizeView>
    <Authorized>
        <RedirectToDashboard ReturnUrl="@ReturnUrl" />
    </Authorized>
    <NotAuthorized Context="notAuthorized">
        <PageTitle>Sign in</PageTitle>

        <section class="login-page">
            <MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="login-container">
                <div class="login-card">
                    <div class="login-brand">
                        <Branding></Branding>
                        <h1 class="login-title">
                            Welcome <span class="gradient-text">back</span>
                        </h1>
                        <p class="login-subtitle">
                            Sign in to access your account.
                        </p>
                    </div>

                    <EditForm Model="_model" OnValidSubmit="HandleLoginAsync">
                        <DataAnnotationsValidator />

                        <MudTextField @bind-Value="_model.Email"
                                      For="@(() => _model.Email)"
                                      Label="Email"
                                      InputType="InputType.Email"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Normal"
                                      Class="login-field mb-2" />

                        <MudTextField @bind-Value="_model.Password"
                                      For="@(() => _model.Password)"
                                      Label="Password"
                                      InputType="InputType.Password"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Normal"
                                      Class="login-field mb-2" />

                        @if (!string.IsNullOrEmpty(_error))
                        {
                            <MudAlert Severity="Severity.Error" Class="mb-4 mt-2">@_error</MudAlert>
                        }

                        <MudButton ButtonType="ButtonType.Submit"
                                   Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   Size="Size.Large"
                                   FullWidth="true"
                                   Disabled="_busy"
                                   Class="mt-4"
                                   Style="border-radius: 14px; text-transform: none; font-weight: 700; padding: 12px 0;">
                            @(_busy ? "Signing in..." : "Sign in")
                        </MudButton>
                    </EditForm>

                    <div class="form-footer">
                        New to Tabajaras?
                        <MudLink Href="/register" Underline="Underline.None" Class="form-footer-link">
                            Create an account
                        </MudLink>
                    </div>
                </div>
            </MudContainer>
        </section>
    </NotAuthorized>
</AuthorizeView>

@code {
    private readonly LoginRequest _model = new();
    private string? _error;
    private bool _busy;

    [Parameter]
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private const string AlreadyLoggedDestination = "/dashboard";

    private async Task HandleLoginAsync()
    {
        _busy = true;
        _error = null;

        var result = await AuthApi.LoginAsync(_model);
        if (result is { Success: true, Data: not null })
        {
            await AuthService.LoginAsync(result.Data);

            var destination = string.IsNullOrWhiteSpace(ReturnUrl) ? AlreadyLoggedDestination : ReturnUrl;
            Navigation.NavigateTo(destination);
            return;
        }

        _error = result.ErrorMessage ?? "Invalid email or password.";
        _busy = false;
    }
}
