@page "/"
@layout HomeLayout

<AuthorizeView>
    <Authorized>
        <RedirectToDashboard />
    </Authorized>
    <NotAuthorized Context="authState">

        <PageTitle>Tabajaras Interviews — Hire brilliant people, faster</PageTitle>

        <div class="home-page">

            <!-- ============================= HERO ============================= -->
            <section class="hero">
                <span class="blob blob-primary"></span>
                <span class="blob blob-tertiary"></span>
                <span class="blob blob-secondary"></span>

                <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="hero-container">
                    <MudGrid Spacing="8" Justify="Justify.Center" Class="align-center">
                        <MudItem xs="12" md="6">
                            <Branding></Branding>

                            <MudText Typo="Typo.h2" Class="hero-title">
                                Run <span class="gradient-text">brilliant interviews</span> and hire with confidence
                            </MudText>

                            <MudText Class="hero-subtitle">
                                Tabajaras Interviews brings scheduling, structured scorecards and real-time
                                collaboration into one place — so every panel stays aligned and every
                                candidate gets a world-class experience.
                            </MudText>

                            <div class="hero-actions">
                                <MudButton Href="/register"
                                           Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Size="Size.Large"
                                           EndIcon="@Icons.Material.Filled.ArrowForward"
                                           Style="border-radius: 24px; text-transform: none; font-weight: 700; padding: 10px 26px;">
                                    Get started free
                                </MudButton>
                                <MudButton Href="/login"
                                           Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           Size="Size.Large"
                                           StartIcon="@Icons.Material.Filled.Login"
                                           Style="border-radius: 24px; text-transform: none; font-weight: 600; padding: 10px 26px;">
                                    Sign in
                                </MudButton>
                            </div>

                            <div class="hero-trust">
                                <div class="avatars">
                                    <span class="avatar a1">AK</span>
                                    <span class="avatar a2">MS</span>
                                    <span class="avatar a3">JD</span>
                                    <span class="avatar a4">RL</span>
                                </div>
                                <MudText Typo="Typo.body2" Class="trust-text">
                                    Trusted by <strong>2,000+</strong> Tabajaras interviewers worldwide
                                </MudText>
                            </div>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <div class="preview-wrap">
                                <div class="preview-card">
                                    <div class="preview-header">
                                        <div class="preview-avatar">AC</div>
                                        <div class="preview-id">
                                            <div class="preview-name">Ana Carvalho</div>
                                            <div class="preview-role">Senior .NET Engineer · Panel 3</div>
                                        </div>
                                    </div>

                                    <div class="preview-section-label">Competency scorecard</div>

                                    @foreach (var s in _scores)
                                    {
                                        <div class="score-row">
                                            <span class="score-label">@s.Label</span>
                                            <span class="bar"><span class="bar-fill" style="width:@(s.Value)%;"></span></span>
                                            <span class="score-val">@s.Rating<span class="score-max">/5</span></span>
                                        </div>
                                    }

                                    <div class="preview-footer">
                                        <div class="reviewers">
                                            <span class="avatar mini r1">JD</span>
                                            <span class="avatar mini r2">MS</span>
                                            <span class="avatar mini r3">+3</span>
                                        </div>
                                        <span class="recommend">
                                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Inherit" Size="Size.Small" />
                                            Strong hire
                                        </span>
                                    </div>
                                </div>

                                <div class="floating-card floating-score">
                                    <span class="float-icon float-icon-amber">
                                        <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Inherit" Size="Size.Small" />
                                    </span>
                                    <span class="float-text">
                                        <span class="float-strong">4.5 / 5</span>
                                        <span class="float-muted">Avg. score</span>
                                    </span>
                                </div>

                                <div class="floating-card floating-next">
                                    <span class="float-icon float-icon-green">
                                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Color="Color.Inherit" Size="Size.Small" />
                                    </span>
                                    <span class="float-text">
                                        <span class="float-strong">Next interview</span>
                                        <span class="float-muted">Today · 2:30 PM</span>
                                    </span>
                                </div>
                            </div>
                        </MudItem>
                    </MudGrid>
                </MudContainer>
            </section>

            <!-- ============================= STATS ============================= -->
            <section class="stats">
                <MudContainer MaxWidth="MaxWidth.Large">
                    <div class="stats-card">
                        <div class="stats-grid">
                            @foreach (var st in _stats)
                            {
                                <div class="stat">
                                    <div class="stat-value">@st.Value</div>
                                    <div class="stat-label">@st.Label</div>
                                </div>
                            }
                        </div>
                    </div>
                </MudContainer>
            </section>

            <!-- ============================= FEATURES ============================= -->
            <section class="features">
                <MudContainer MaxWidth="MaxWidth.Large">
                    <div class="section-head">
                        <MudText Typo="Typo.h3" Class="section-kicker">Everything you need</MudText>
                        <MudText Typo="Typo.h4" Class="section-title">One platform for the whole hiring loop</MudText>
                        <MudText Class="section-sub">
                            From the first screen to the final offer, give your interviewers the structure and
                            insight they need to choose the right people — every single time.
                        </MudText>
                    </div>

                    <MudGrid Spacing="6">
                        @foreach (var f in _features)
                        {
                            <MudItem xs="12" sm="6" md="4">
                                <div class="feature-card">
                                    <div class="feature-icon i-@(f.Tone)">
                                        <MudIcon Icon="@f.Icon" Color="Color.Inherit" Size="Size.Large" />
                                    </div>
                                    <MudText Typo="Typo.h6" Class="feature-title">@f.Title</MudText>
                                    <MudText Typo="Typo.body2" Class="feature-desc">@f.Description</MudText>
                                </div>
                            </MudItem>
                        }
                    </MudGrid>
                </MudContainer>
            </section>

            <!-- ============================= HOW IT WORKS ============================= -->
            <section class="steps">
                <MudContainer MaxWidth="MaxWidth.Large">
                    <div class="section-head">
                        <MudText Typo="Typo.h3" Class="section-kicker">How it works</MudText>
                        <MudText Typo="Typo.h4" Class="section-title">From open role to great hire in three steps</MudText>
                    </div>

                    <MudGrid Spacing="6">
                        @foreach (var step in _steps)
                        {
                            <MudItem xs="12" md="4">
                                <div class="step">
                                    <div class="step-num">@step.Num</div>
                                    <MudText Typo="Typo.h6" Class="step-title">@step.Title</MudText>
                                    <MudText Typo="Typo.body2" Class="step-desc">@step.Description</MudText>
                                </div>
                            </MudItem>
                        }
                    </MudGrid>
                </MudContainer>
            </section>

            <!-- ============================= CTA ============================= -->
            <section class="cta-band-wrap">
                <MudContainer MaxWidth="MaxWidth.Large">
                    <div class="cta-band">
                        <MudText Typo="Typo.h3" Class="cta-title">Ready to transform your hiring?</MudText>
                        <MudText Class="cta-sub">
                            Join the Tabajaras teams running fairer, faster and friendlier interviews today.
                        </MudText>
                        <div class="cta-actions">
                            <MudButton Href="/register"
                                       Variant="Variant.Filled"
                                       Size="Size.Large"
                                       EndIcon="@Icons.Material.Filled.RocketLaunch"
                                       Style="background:#ffffff; color: var(--mud-palette-primary); border-radius: 24px; text-transform: none; font-weight: 700; padding: 10px 28px;">
                                Get started free
                            </MudButton>
                            <MudButton Href="/login"
                                       Variant="Variant.Text"
                                       Size="Size.Large"
                                       Style="color:#ffffff; border: 1px solid rgba(255,255,255,0.6); border-radius: 24px; text-transform: none; font-weight: 600; padding: 10px 28px;">
                                Sign in
                            </MudButton>
                        </div>
                    </div>
                </MudContainer>
            </section>

        </div>

    </NotAuthorized>
</AuthorizeView>

@code {
    [CascadingParameter]
    public HomeLayout? Layout { get; set; }

    private readonly (int Value, string Label, string Rating)[] _scores =
    {
        (96, "System design", "4.8"),
        (82, "Problem solving", "4.1"),
        (90, "Communication", "4.5"),
    };

    private readonly (string Value, string Label)[] _stats =
    {
        ("40%", "Faster time-to-hire"),
        ("2,000+", "Active interviewers"),
        ("93%", "Candidate satisfaction"),
        ("15k+", "Interviews run"),
    };

    private readonly (string Icon, string Title, string Description, string Tone)[] _features =
    {
        (Icons.Material.Filled.CalendarMonth, "Smart scheduling", "Auto-match interviewer availability across time zones and book full panels in a single click.", "primary"),
        (Icons.Material.Filled.FactCheck, "Structured scorecards", "Standardised competency rubrics keep every evaluation fair, consistent and bias-aware.", "secondary"),
        (Icons.Material.Filled.Groups, "Live collaboration", "Co-interview in real time, capture private notes and reach a decision together, faster.", "tertiary"),
        (Icons.Material.Filled.Videocam, "Built-in video rooms", "Run remote interviews with shared questions and timeboxing — with no extra tools to juggle.", "primary"),
        (Icons.Material.Filled.Insights, "Hiring insights", "Track pipeline health, time-to-hire and panel performance with live, shareable dashboards.", "secondary"),
        (Icons.Material.Filled.Verified, "Candidate experience", "Branded, friendly scheduling and reminders that make every candidate feel genuinely valued.", "tertiary"),
    };

    private readonly (string Num, string Title, string Description)[] _steps =
    {
        ("1", "Define the role & rubric", "Spin up a job with a ready-made competency scorecard your whole panel will share."),
        ("2", "Invite the panel & schedule", "Match availability automatically and send branded invites to candidates in seconds."),
        ("3", "Score, align & decide", "Collect structured feedback, compare candidates side by side and make a confident hire."),
    };
}