@*
    Reusable empty-state placeholder with an icon, title, optional description and
    optional call-to-action (supplied via the Actions render fragment).
*@

<div class="d-flex flex-column align-center justify-center text-center pa-8 @Class">
    <MudIcon Icon="@Icon" Size="Size.Large" Class="mb-3 mud-text-secondary" Style="font-size: 3rem;" />
    <MudText Typo="Typo.subtitle1">@Title</MudText>
    @if (!string.IsNullOrWhiteSpace(Description))
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary mt-1" Style="max-width: 420px;">
            @Description
        </MudText>
    }
    @if (Actions is not null)
    {
        <div class="mt-4">
            @Actions
        </div>
    }
</div>

@code {
    [Parameter] public string Title { get; set; } = "Nothing here yet";

    [Parameter] public string? Description { get; set; }

    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Inbox;

    /// <summary>Optional call-to-action buttons.</summary>
    [Parameter] public RenderFragment? Actions { get; set; }

    [Parameter] public string? Class { get; set; }
}
