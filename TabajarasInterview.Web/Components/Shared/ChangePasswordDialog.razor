@using TabajarasInterview.Web.Models
@inject IUserApiService UserApi
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync">
            <DataAnnotationsValidator />

            <MudTextField @bind-Value="_model.CurrentPassword"
                          For="@(() => _model.CurrentPassword)"
                          Label="Current password"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Margin="Margin.Normal"
                          Class="mb-2" />

            <MudTextField @bind-Value="_model.NewPassword"
                          For="@(() => _model.NewPassword)"
                          Label="New password"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Margin="Margin.Normal"
                          Class="mb-2" />

            <MudTextField @bind-Value="_model.ConfirmNewPassword"
                          For="@(() => _model.ConfirmNewPassword)"
                          Label="Confirm new password"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Margin="Margin.Normal"
                          Class="mb-2" />

            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Class="mt-2">@_error</MudAlert>
            }

            <div class="d-flex justify-end gap-2 mt-4">
                <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
                <MudButton ButtonType="ButtonType.Submit"
                           Color="Color.Primary"
                           Variant="Variant.Filled"
                           Disabled="_busy">
                    @(_busy ? "Updating..." : "Change password")
                </MudButton>
            </div>
        </EditForm>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private readonly ChangePasswordRequest _model = new();
    private bool _busy;
    private string? _error;

    private async Task HandleSubmitAsync()
    {
        _busy = true;
        _error = null;

        var result = await UserApi.ChangePasswordAsync(_model);
        if (result is { Success: true })
        {
            Snackbar.Add("Password changed.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
            return;
        }

        _error = result.ErrorMessage ?? "Could not change your password. Please try again.";
        _busy = false;
    }

    private void Cancel() => MudDialog.Cancel();
}
