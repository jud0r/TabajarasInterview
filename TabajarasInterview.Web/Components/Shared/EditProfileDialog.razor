@inject IUserApiService UserApi
@inject AuthService AuthService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (_loading)
        {
            <div class="d-flex justify-center py-4">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else
        {
            <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync">
                <DataAnnotationsValidator />

                <MudTextField @bind-Value="_model.FirstName"
                              For="@(() => _model.FirstName)"
                              Label="First name"
                              Variant="Variant.Outlined"
                              Margin="Margin.Normal"
                              Class="mb-2" />

                <MudTextField @bind-Value="_model.LastName"
                              For="@(() => _model.LastName)"
                              Label="Last name"
                              Variant="Variant.Outlined"
                              Margin="Margin.Normal"
                              Class="mb-2" />

                @if (!string.IsNullOrEmpty(_error))
                {
                    <MudAlert Severity="Severity.Error" Class="mt-2">@_error</MudAlert>
                }

                <div class="d-flex justify-end gap-2 mt-4">
                    <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
                    <MudButton ButtonType="ButtonType.Submit"
                               Color="Color.Primary"
                               Variant="Variant.Filled"
                               Disabled="_busy">
                        @(_busy ? "Saving..." : "Save changes")
                    </MudButton>
                </div>
            </EditForm>
        }
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private readonly UpdateProfileRequest _model = new();
    private bool _loading = true;
    private bool _busy;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var result = await UserApi.GetCurrentAsync();
        if (result is { Success: true, Data: not null })
        {
            _model.FirstName = result.Data.FirstName;
            _model.LastName = result.Data.LastName;
        }
        else
        {
            _error = result.ErrorMessage ?? "Could not load your profile.";
        }

        _loading = false;
    }

    private async Task HandleSubmitAsync()
    {
        _busy = true;
        _error = null;

        var result = await UserApi.UpdateProfileAsync(_model);
        if (result is { Success: true, Data: not null })
        {
            await AuthService.RefreshUserAsync(result.Data);
            Snackbar.Add("Profile updated.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
            return;
        }

        _error = result.ErrorMessage ?? "Could not update your profile. Please try again.";
        _busy = false;
    }

    private void Cancel() => MudDialog.Cancel();
}
